{
  "version": "7.3",
  "screens": [
    {
      "id": "BUSINESS_SETUP",
      "title": "Set up your business",
      "terminal": false,
      "data": {
        "whatsappPhone": {
          "type": "string",
          "__example__": "+2348012345678"
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "businessSetupForm",
            "children": [
              
              {
                "type": "TextBody",
                "text": "Tell us about your business so Binda can help you record sales and track customers."
              },
              {
                "type": "TextInput",
                "name": "businessName",
                "label": "Business",
                "required": true,
                "input-type": "text",
                "helper-text": "Fill this with your business name. Ex: Amazing Cakes"
              },
              {
                "type": "TextInput",
                "name": "ownerName",
                "label": "Owner name",
                "required": true,
                "input-type": "text",
                "helper-text": "Fill this with your name. Ex: Uncle John"
              },
              {
                "type": "Dropdown",
                "name": "categoryId",
                "label": "Category",
                "required": true,
                "data-source": [
                  {
                    "id": "773f0b14-1a00-41f0-95b9-4aa925391512",
                    "title": "Agriculture"
                  },
                  {
                    "id": "c81c0e5e-32f1-433d-bb14-f7c8cf96dc62",
                    "title": "Beauty"

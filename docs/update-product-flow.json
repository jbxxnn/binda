{
  "version": "7.3",
  "data_api_version": "3.0",
  "routing_model": {
    "UPDATE_PRODUCT": []
  },
  "screens": [
    {
      "id": "UPDATE_PRODUCT",
      "title": "Update product",
      "terminal": true,
      "success": true,
      "data": {
        "productId": {
          "type": "string",
          "__example__": "11111111-1111-1111-1111-111111111111"
        },
        "currentName": {
          "type": "string",
          "__example__": "Small Birthday Cake"
        },
        "currentPrice": {
          "type": "string",
          "__example__": "15000"
        },
        "currentStock": {
          "type": "string",
          "__example__": "5"
        },
        "currentActive": {
          "type": "string",
          "__example__": "active"
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "updateProductForm",
            "children": [
              {
                "type": "TextHeading",
                "text": "Update product"
              },
              {
                "type": "TextBody",
                "text": "Current name: ${data.currentName}"
              },
              {
                "type": "TextBody",
                "text": "Current price: ${data.currentPrice}"
              },
              {
                "type": "TextBody",
                "text": "Current stock: ${data.currentStock}"
              },
              {
                "type": "TextBody",
                "text": "Current status: ${data.currentActive}"
              },
              {
                "type": "TextBody",
                "text": "Leave any field empty if you want to keep the current value."
              },
              {
                "type": "TextInput",
                "name": "productName",
                "label": "New product name",
                "required": false,
                "input-type": "text"
              },
              {
                "type": "TextInput",
                "name": "unitPrice",
                "label": "New price",
                "required": false,
                "input-type": "number"
              },
              {
                "type": "TextInput",
                "name": "stockQuantity",
                "label": "New stock",
                "required": false,
                "input-type": "number"
              },
              {
                "type": "Dropdown",
                "name": "availabilityAction",
                "label": "Availability",
                "required": false,
                "data-source": [
                  { "id": "keep", "title": "Keep current status" },
                  { "id": "active", "title": "Mark active" },
                  { "id": "inactive", "title": "Mark inactive" }
                ]
              },
              {
                "type": "Footer",
                "label": "Save changes",
                "on-click-action": {
                  "name": "complete",
                  "payload": {
                    "productId": "${data.productId}",
                    "productName": "${form.productName}",
                    "unitPrice": "${form.unitPrice}",
                    "stockQuantity": "${form.stockQuantity}",
                    "availabilityAction": "${form.availabilityAction}"
                  }
                }
              }
            ]
          }
        ]
      }
    }
  ]
}
